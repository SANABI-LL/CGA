{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "skipLibCheck": true,
    "outDir": "cdk.out",
    "declaration": true,
    "experimentalDecorators": true
  },
  "include": ["bin/**/*.ts", "stacks/**/*.ts", "constructs/**/*.ts"],
  "exclude": ["node_modules", "cdk.out"]
}
